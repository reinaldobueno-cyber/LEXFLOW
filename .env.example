CONTROLJUS_URL=https://app.controljus.com.br/publicacoes/recortes/arquivadas
CONTROLJUS_USER=seu_usuario_aqui
CONTROLJUS_PASSWORD=sua_senha_aqui

# Autenticação LexFlow SaaS.
# Em produção, configure como Cloudflare secrets, nunca em wrangler.jsonc.
MASTER_ADMIN_EMAIL=reinaldo@seudominio.com.br
MASTER_ADMIN_PASSWORD=defina_uma_senha_forte
MASTER_ADMIN_NAME=Reinaldo
SETTINGS_ENCRYPTION_KEY=gere_um_token_longo_aleatorio
AUTH_SECRET=gere_outro_token_longo_aleatorio

# Ajuste estes seletores depois de inspecionar a tela real de login, se necessario.
CONTROLJUS_USER_SELECTOR=input[type="email"], input[name="email"], input[name="usuario"], input[name="login"], input[type="text"]
CONTROLJUS_PASSWORD_SELECTOR=input[type="password"]
CONTROLJUS_SUBMIT_SELECTOR=button[type="submit"], input[type="submit"]
CONTROLJUS_HEADLESS=true

# Usado pelo servidor local/API privada.
PORT=8787
CONTROLJUS_CACHE_TTL_MS=900000

# Opcional: se definido, protege /api/controljus/* com Authorization: Bearer <token>.
CONTROLJUS_API_TOKEN=

# Fallback opcional: backend privado externo como destino do proxy.
CONTROLJUS_BACKEND_URL=https://SEU-BACKEND/api/controljus/publicacoes
CONTROLJUS_BACKEND_TOKEN=

# A3 no MVP: LexFlow abre a fonte oficial no navegador do advogado.
# O token fisico fica na maquina do usuario; nao ha secret de A3 no Worker.

# Fallback avancado opcional: agente local somente se o escritorio aceitar automacao instalada.
LEXFLOW_A3_HOST=127.0.0.1
LEXFLOW_A3_PORT=48731
LEXFLOW_ORIGIN=https://lexflow.reinaldo-bueno.workers.dev
