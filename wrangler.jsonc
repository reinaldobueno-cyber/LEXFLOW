{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lexflow",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-07",
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "*/30 11-23 * * mon-fri"
    ]
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
